APP_IDEA_FORWARDING_ENABLED=false
APP_ALLOWED_ORIGINS=https://1ststep.ai,https://www.1ststep.ai,https://main-website-repo.vercel.app
APP_IDEA_RATE_LIMIT_MAX=12
APP_IDEA_RATE_LIMIT_WINDOW_MS=600000
APP_IDEA_RETENTION_SECONDS=7776000
APP_IDEA_GHL_WEBHOOK_URL=
APP_IDEA_ZAPIER_WEBHOOK_URL=
APP_IDEA_MAKE_WEBHOOK_URL=
APP_IDEA_CUSTOM_WEBHOOK_URL=

# Resend delivers App Idea Checker reports and Website Fit Check requests.
# The Fit Check endpoint fails closed when these values are not configured.
RESEND_API_KEY=
APP_IDEA_NOTIFY_TO=
APP_IDEA_NOTIFY_FROM=

# Shared secret for the confirmed-booking workflow webhook from LeadConnector.
# Send it as Authorization: Bearer <secret> or x-leadconnector-webhook-secret.
LEADCONNECTOR_ANALYTICS_WEBHOOK_SECRET=

# Optional Vercel KV storage. If omitted, another delivery path (Resend or an
# enabled webhook) must succeed or the API returns 503 instead of claiming save success.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Optional live Google reviews on the homepage. If omitted, the site shows a safe review CTA fallback.
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACE_ID=

# Owner-only 1stStep Studio access. Use a unique password of at least 12
# characters and a separately generated random session secret of at least 32.
FIRSTSTEP_ADMIN_PASSWORD=
FIRSTSTEP_ADMIN_SESSION_SECRET=

# Admin quotes use the existing RESEND_API_KEY and send as:
# Evan at 1stStep.ai <evan@1ststep.ai>
# The 1ststep.ai domain must be verified in Resend before production delivery.
